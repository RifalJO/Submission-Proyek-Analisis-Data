                "\n",
                "plt.tight_layout()\n",
                "plt.show()\n",
                "\n",
                "# Tampilkan statistik\n",
                "print('\\n=== RATA-RATA PM2.5 PER MUSIM ===')\n",
                "print(df.groupby('musim')['PM2.5'].mean().reindex(season_order))\n",
                "print('\\n=== RATA-RATA PM2.5 PER WAKTU HARI ===')\n",
                "print(df.groupby('waktu_hari')['PM2.5'].mean().reindex(time_order))"
            ]
        },
