        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "### Pertanyaan Bisnis 1: Stasiun Mana yang Memiliki Rata-rata Polusi PM2.5 Paling Tinggi?"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Hitung rata-rata PM2.5 per stasiun\n",
                "station_pm25 = df.groupby('station')['PM2.5'].mean().sort_values(ascending=True)\n",
                "\n",
                "# Hitung rata-rata keseluruhan\n",
                "overall_avg = df['PM2.5'].mean()\n",
                "\n",
                "# Buat warna: merah untuk di atas rata-rata, biru untuk di bawah\n",
                "colors = ['#e74c3c' if x > overall_avg else '#3498db' for x in station_pm25.values]\n",
                "\n",
                "# Visualisasi\n",
                "plt.figure(figsize=(12, 8))\n",
                "bars = plt.barh(station_pm25.index, station_pm25.values, color=colors)\n",
                "\n",
                "# Tambahkan garis rata-rata keseluruhan\n",
                "plt.axvline(x=overall_avg, color='#f39c12', linestyle='--', linewidth=2, label=f'Rata-rata Keseluruhan: {overall_avg:.2f}')\n",
                "\n",
                "plt.xlabel('Rata-rata PM2.5 (μg/m³)', fontsize=12)\n",
                "plt.ylabel('Stasiun', fontsize=12)\n",
                "plt.title('Perbandingan Rata-rata PM2.5 per Stasiun', fontsize=14, fontweight='bold')\n",
                "plt.legend()\n",
                "plt.grid(axis='x', alpha=0.3)\n",
                "\n",
                "# Tambahkan label nilai di setiap bar\n",
                "for i, (station, value) in enumerate(station_pm25.items()):\n",
                "    plt.text(value + 2, i, f'{value:.2f}', va='center', fontsize=10)\n",
                "\n",
                "plt.tight_layout()\n",
                "plt.show()\n",
                "\n",
                "# Tampilkan 3 tertinggi dan 3 terendah\n",
                "print('\\n=== 3 STASIUN PALING TERCEMAR ===')\n",
                "print(station_pm25.tail(3)[::-1])\n",
                "print('\\n=== 3 STASIUN PALING BERSIH ===')\n",
                "print(station_pm25.head(3))"
            ]
        },
        {
            "cell_type": "markdown",
