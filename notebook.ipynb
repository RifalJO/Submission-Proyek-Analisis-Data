                "               (row['lon'], row['lat']),\n",
                "               fontsize=9,\n",
                "               ha='center',\n",
                "               va='bottom',\n",
                "               fontweight='bold')\n",
                "\n",
                "# Buat custom legend\n",
                "from matplotlib.patches import Patch\n",
                "legend_elements = [Patch(facecolor=color, label=category) \n",
                "                   for category, color in aqi_colors.items()]\n",
                "ax.legend(handles=legend_elements, title='Kategori AQI', loc='upper right')\n",
