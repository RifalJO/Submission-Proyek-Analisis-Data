        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "### Pertanyaan Bisnis 2: Bagaimana Pola Polusi PM2.5 Berubah Sepanjang Musim dan Waktu dalam Sehari?"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Buat kolom 'musim' berdasarkan bulan\n",
                "def get_season(month):\n",
                "    if month in [3, 4, 5]:\n",
                "        return 'Semi'\n",
                "    elif month in [6, 7, 8]:\n",
                "        return 'Panas'\n",
                "    elif month in [9, 10, 11]:\n",
                "        return 'Gugur'\n",
                "    else:  # 12, 1, 2\n",
                "        return 'Dingin'\n",
                "\n",
                "# Ekstrak bulan dari datetime\n",
                "df['month'] = df['datetime'].dt.month\n",
                "df['musim'] = df['month'].apply(get_season)\n",
                "\n",
                "# Buat kolom 'waktu_hari' berdasarkan jam\n",
                "df['hour'] = df['datetime'].dt.hour\n",
                "\n",
                "def get_time_of_day(hour):\n",
                "    if 6 <= hour <= 11:\n",
                "        return 'Pagi'\n",
                "    elif 12 <= hour <= 17:\n",
                "        return 'Siang'\n",
                "    elif 18 <= hour <= 23:\n",
                "        return 'Sore'\n",
                "    else:  # 0-5\n",
                "        return 'Malam'\n",
                "\n",
                "df['waktu_hari'] = df['hour'].apply(get_time_of_day)\n",
                "\n",
                "print('Kolom musim dan waktu_hari berhasil dibuat!')\n",
                "print(f'\\nDistribusi data per musim:')\n",
                "print(df['musim'].value_counts())\n",
                "print(f'\\nDistribusi data per waktu hari:')\n",
                "print(df['waktu_hari'].value_counts())"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Visualisasi 1: Boxplot PM2.5 per Musim\n",
                "fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n",
                "\n",
                "# Boxplot per musim\n",
                "season_order = ['Semi', 'Panas', 'Gugur', 'Dingin']\n",
                "sns.boxplot(data=df, x='musim', y='PM2.5', order=season_order, ax=axes[0], palette='viridis')\n",
                "axes[0].set_xlabel('Musim', fontsize=12)\n",
                "axes[0].set_ylabel('Konsentrasi PM2.5 (μg/m³)', fontsize=12)\n",
                "axes[0].set_title('Distribusi PM2.5 per Musim', fontsize=14, fontweight='bold')\n",
                "axes[0].grid(axis='y', alpha=0.3)\n",
                "\n",
    # Tambahkan mean per musim\n","season_means = df.groupby('musim')['PM2.5'
                ].mean()\n","for i, season in enumerate(season_order):\n","    axes[
                    0
                ].text(i, season_means[season
                ] + 5, f'Mean: {season_means[season
                    ]:.1f
                }', \n","                 ha='center', fontsize=10, fontweight='bold')\n","\n",
                "# Heatmap: PM2.5 berdasarkan waktu_hari dan stasiun\n",
                "heatmap_data = df.pivot_table(values='PM2.5', index='station', columns='waktu_hari', aggfunc='mean')\n",
                "time_order = ['Pagi', 'Siang', 'Sore', 'Malam']\n",
                "heatmap_data = heatmap_data[time_order]\n",
                "\n",
                "sns.heatmap(heatmap_data, annot=True, fmt='.1f', cmap='YlOrRd', ax=axes[1], \n",
                "            cbar_kws={'label': 'PM2.5 (μg/m³)'})\n",
                "axes[1].set_xlabel('Waktu dalam Sehari', fontsize=12)\n",
