            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "## 4. Analisis Lanjutan — Geospatial Analysis"
            ]
        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "### Langkah 1 — Hitung Statistik per Stasiun"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Hitung statistik per stasiun\n",
                "station_stats = df.groupby('station').agg({\n",
                "    'PM2.5': 'mean',\n",
                "    'PM10': 'mean',\n",
                "    'NO2': 'mean',\n",
                "    'SO2': 'mean',\n",
                "    'CO': 'mean',\n",
                "    'O3': 'mean'\n",
                "}).round(2)\n",
                "\n",
                "station_stats.columns = ['avg_pm25', 'avg_pm10', 'avg_no2', 'avg_so2', 'avg_co', 'avg_o3']\n",
                "station_stats = station_stats.reset_index()\n",
                "\n",
                "# Klasifikasikan kategori AQI berdasarkan avg_pm25\n",
                "def get_aqi_category(pm25):\n",
                "    if pm25 <= 12:\n",
                "        return 'Baik'\n",
                "    elif pm25 <= 35.4:\n",
                "        return 'Sedang'\n",
                "    elif pm25 <= 55.4:\n",
                "        return 'Tidak Sehat'\n",
                "    elif pm25 <= 150.4:\n",
                "        return 'Sangat Tidak Sehat'\n",
                "    else:\n",
                "        return 'Berbahaya'\n",
                "\n",
                "station_stats['aqi_category'] = station_stats['avg_pm25'].apply(get_aqi_category)\n",
                "\n",
                "print('=== STATISTIK PER STASIUN ===')\n",
                "station_stats.sort_values('avg_pm25', ascending=False)"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Koordinat stasiun (hardcode)\n",
                "station_coords = {\n",
                "    'Aotizhongxin': {'lat': 39.9829, 'lon': 116.3971},\n",
                "    'Changping': {'lat': 40.2175, 'lon': 116.2309},\n",
                "    'Dingling': {'lat': 40.2925, 'lon': 116.2200},\n",
                "    'Dongsi': {'lat': 39.9290, 'lon': 116.4175},\n",
                "    'Guanyuan': {'lat': 39.9290, 'lon': 116.3390},\n",
                "    'Gucheng': {'lat': 39.9140, 'lon': 116.1840},\n",
                "    'Huairou': {'lat': 40.3281, 'lon': 116.6283},\n",
                "    'Nongzhanguan': {'lat': 39.9368, 'lon': 116.4605},\n",
                "    'Shunyi': {'lat': 40.1270, 'lon': 116.6557},\n",
                "    'Tiantan': {'lat': 39.8863, 'lon': 116.4079},\n",
                "    'Wanliu': {'lat': 39.9870, 'lon': 116.2882},\n",
                "    'Wanshouxigong': {'lat': 39.8780, 'lon': 116.3520}\n",
                "}\n",
                "\n",
                "# Tambahkan koordinat ke station_stats\n",
                "station_stats['lat'] = station_stats['station'].apply(lambda x: station_coords[x]['lat'])\n",
                "station_stats['lon'] = station_stats['station'].apply(lambda x: station_coords[x]['lon'])\n",
                "\n",
                "station_stats"
            ]
        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "### Langkah 2 — Buat Peta Interaktif dengan Folium"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Mapping warna berdasarkan kategori AQI\n",
                "aqi_colors = {\n",
                "    'Baik': '#2ecc71',           # Hijau\n",
                "    'Sedang': '#f1c40f',         # Kuning\n",
                "    'Tidak Sehat': '#e67e22',    # Oranye\n",
                "    'Sangat Tidak Sehat': '#e74c3c',  # Merah\n",
                "    'Berbahaya': '#8e44ad'       # Ungu\n",
                "}\n",
                "\n",
                "# Buat peta interaktif\n",
                "m = folium.Map(location=[39.9042, 116.4074], zoom_start=10, tiles='CartoDB positron')\n",
                "\n",
                "# Tambahkan marker untuk setiap stasiun\n",
                "for _, row in station_stats.iterrows():\n",
                "    # Buat popup content dalam Bahasa Indonesia\n",
                "    popup_html = f\"\"\"\n",
                "    <div style=\"font-family: Arial; font-size: 12px;\">\n",
                "        <h4 style=\"margin-bottom: 10px; color: {aqi_colors[row['aqi_category']]};\">{row['station']}</h4>\n",
                "        <b>Rata-rata PM2.5:</b> {row['avg_pm25']:.2f} μg/m³<br>\n",
                "        <b>Rata-rata PM10:</b> {row['avg_pm10']:.2f} μg/m³<br>\n",
                "        <b>Rata-rata NO2:</b> {row['avg_no2']:.2f} μg/m³<br>\n",
                "        <b>Kategori AQI:</b> <span style=\"color: {aqi_colors[row['aqi_category']]}; font-weight: bold;\">{row['aqi_category']}</span>\n",
                "    </div>\n",
                "    \"\"\"\n",
                "    \n",
                "    # Tambahkan CircleMarker\n",
                "    folium.CircleMarker(\n",
                "        location=[row['lat'], row['lon']],\n",
                "        radius=row['avg_pm25'] / 5,  # Radius proporsional dengan polusi\n",
                "        color=aqi_colors[row['aqi_category']],\n",
                "        fill=True,\n",
                "        fill_color=aqi_colors[row['aqi_category']],\n",
                "        fill_opacity=0.6,\n",
                "        popup=folium.Popup(popup_html, max_width=300),\n",
                "        tooltip=f\"{row['station']}: {row['avg_pm25']:.2f} μg/m³\"\n",
                "    ).add_to(m)\n",
                "\n",
                "# Tambahkan legend kustom\n",
                "legend_html = '''\n",
                "<div style=\"position: fixed; bottom: 50px; left: 50px; width: 200px; height: 180px; \n",
                "             background-color: white; border: 2px solid grey; z-index: 9999; font-size: 12px;\n",
                "             padding: 10px; border-radius: 5px; box-shadow: 2px 2px 5px rgba(0,0,0,0.3);\">\n",
                "    <h4 style=\"margin-top: 0; margin-bottom: 10px;\">Kategori AQI (PM2.5)</h4>\n",
                "    <div style=\"display: flex; align-items: center; margin-bottom: 5px;\">\n",
                "        <div style=\"width: 20px; height: 20px; background-color: #2ecc71; margin-right: 10px; border-radius: 50%;\"></div>\n",
                "        <span>Baik (0-12)</span>\n",
                "    </div>\n",
                "    <div style=\"display: flex; align-items: center; margin-bottom: 5px;\">\n",
                "        <div style=\"width: 20px; height: 20px; background-color: #f1c40f; margin-right: 10px; border-radius: 50%;\"></div>\n",
                "        <span>Sedang (12-35.4)</span>\n",
                "    </div>\n",
                "    <div style=\"display: flex; align-items: center; margin-bottom: 5px;\">\n",
                "        <div style=\"width: 20px; height: 20px; background-color: #e67e22; margin-right: 10px; border-radius: 50%;\"></div>\n",
                "        <span>Tidak Sehat (35.4-55.4)</span>\n",
                "    </div>\n",
                "    <div style=\"display: flex; align-items: center; margin-bottom: 5px;\">\n",
                "        <div style=\"width: 20px; height: 20px; background-color: #e74c3c; margin-right: 10px; border-radius: 50%;\"></div>\n",
                "        <span>Sangat Tidak Sehat (55.4-150.4)</span>\n",
                "    </div>\n",
                "    <div style=\"display: flex; align-items: center;\">\n",
                "        <div style=\"width: 20px; height: 20px; background-color: #8e44ad; margin-right: 10px; border-radius: 50%;\"></div>\n",
                "        <span>Berbahaya (>150.4)</span>\n",
                "    </div>\n",
                "</div>\n",
                "'''\n",
                "\n",
                "m.get_root().html.add_child(folium.Element(legend_html))\n",
                "\n",
                "# Simpan peta\n",
                "m.save('assets/beijing_air_quality_map.html')\n",
                "print('Peta interaktif berhasil disimpan sebagai assets/beijing_air_quality_map.html')\n",
                "\n",
                "# Tampilkan peta inline\n",
                "display(m)"
            ]
        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "### Langkah 3 — Chart Statis Geospasial"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Scatter plot geospasial dengan matplotlib\n",
                "fig, ax = plt.subplots(figsize=(14, 10))\n",
                "\n",
                "# Plot setiap stasiun\n",
                "for _, row in station_stats.iterrows():\n",
                "    ax.scatter(\n",
                "        row['lon'], row['lat'],\n",
                "        s=row['avg_pm25'] * 3,  # Ukuran proporsional dengan PM2.5\n",
                "        c=aqi_colors[row['aqi_category']],\n",
                "        alpha=0.6,\n",
                "        edgecolors='black',\n",
